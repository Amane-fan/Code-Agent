# 模型配置。推荐使用 LangChain init_chat_model 支持的 provider:model 格式。
MODEL_NAME=openai:gpt-4.1-mini
MODEL_TEMPERATURE=0
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT_SECONDS=120
MODEL_CONTEXT_WINDOW=128000

# Provider API Key。
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# 兼容 OpenAI API 的服务可使用 base_url。
MODEL_BASE_URL=

# Agent 行为配置。
TOKEN_BUDGET_RATIO=0.85
MAX_REPAIR_ATTEMPTS=2
MAX_TOOL_REPAIR_ATTEMPTS=1
MAX_COMPACT_ATTEMPTS=2
MAX_CONTEXT_CHARS_PER_TOOL_RESULT=12000
SHELL_TIMEOUT_SECONDS=60
REQUIRE_APPROVAL_FOR_WRITE=true
LOG_LEVEL=INFO
LOG_DIR=.agent/logs
SKILLS_DIR=skills
CHECKPOINT_DB=.agent/checkpoints.sqlite
